# SmartOPD Backend Environment Configuration
# Copy this to .env and update with your values

# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
# Local MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/smartopd

# OR MongoDB Atlas (Cloud)
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/smartopd?retryWrites=true&w=majority

# Authentication
JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@smartopd.com

# SMS Configuration (Twilio or similar)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE=+1234567890

# Payment Gateway (Stripe/Razorpay)
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug
